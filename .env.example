# Azure OpenAI
OPENAI_API_KEY=your_azure_openai_api_key
OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# IFRC GO API
GO_AUTH_TOKEN=your_base64_encoded_token

# Pipeline settings
LAST_N_DAYS=7

# SendGrid email notifications
SENDGRID_API_KEY=SG.xxxxx
EMAIL_FROM=appeals-monitor@example.com

# KoboToolbox (email recipient list)
KOBO_API_URL=https://kobo.ifrc.org
KOBO_API_TOKEN=your_kobo_api_token
KOBO_FORM_UID=aXXXXXXXXXXXXXX
